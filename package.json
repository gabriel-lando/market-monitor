{
    "name": "market-monitor",
    "private": true,
    "version": "0.1.0",
    "packageManager": "pnpm@11.6.0",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "build": "pnpm -r build",
        "dev:backend": "pnpm --filter @market-monitor/backend dev",
        "dev:frontend": "pnpm --filter @market-monitor/frontend dev",
        "lint": "pnpm -r lint",
        "typecheck": "pnpm -r typecheck",
        "db:migrate": "pnpm --filter @market-monitor/db migrate",
        "db:seed": "pnpm --filter @market-monitor/db seed"
    }
}